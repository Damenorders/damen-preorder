# Copy this file to .env.local and fill in the values from your Supabase
# project (Dashboard → Project Settings → API, and → Database for the
# connection string). NEVER commit .env.local.

# Project URL, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# anon public key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key (SECRET — server/seed only)
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (Dashboard → Connect → "Transaction pooler"), e.g.
# postgresql://postgres.abcd1234:YOUR_DB_PASSWORD@aws-0-ca-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Password assigned to the four seed users (change after launch)
SEED_USER_PASSWORD=Damen2026!
